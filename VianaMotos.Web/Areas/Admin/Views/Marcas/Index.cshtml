@model IEnumerable<VianaMotos.Web.Models.Marca>

<h1>Marcas</h1>

<p>
    <a asp-area="Admin"
       asp-controller="Marcas"
       asp-action="Create"
       class="btn btn-primary">
        Nova Marca
    </a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Ativa</th>
            <th width="200">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var marca in Model)
        {
            <tr>
                <td>@marca.Nome</td>
                <td>@marca.Ativa</td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@marca.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@marca.Id"
                       class="btn btn-danger btn-sm">
                        Excluir
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>