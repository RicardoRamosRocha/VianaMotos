@model VianaMotos.Web.Models.Moto

<h1>Excluir Moto</h1>

<div class="alert alert-danger">
    Tem certeza que deseja excluir esta moto?
</div>

<dl class="row">

    <dt class="col-sm-2">Modelo</dt>
    <dd class="col-sm-10">@Model.Modelo</dd>

    <dt class="col-sm-2">Marca</dt>
    <dd class="col-sm-10">@Model.Marca?.Nome</dd>

    <dt class="col-sm-2">Categoria</dt>
    <dd class="col-sm-10">@Model.Categoria?.Nome</dd>

    <dt class="col-sm-2">Ano</dt>
    <dd class="col-sm-10">@Model.Ano</dd>

    <dt class="col-sm-2">Valor</dt>
    <dd class="col-sm-10">@Model.Valor.ToString("C")</dd>

</dl>

<form asp-action="Delete" method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Confirmar Exclusão
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancelar
    </a>

</form>