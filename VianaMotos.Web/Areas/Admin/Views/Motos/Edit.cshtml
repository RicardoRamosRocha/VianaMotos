@model VianaMotos.Web.ViewModels.MotoViewModel

<div asp-validation-summary="All" class="text-danger"></div>

<div class="card shadow-sm">
    <div class="card-body">

        <h1 class="mb-4">Editar Moto</h1>


<form asp-action="Edit"
      method="post"
      enctype="multipart/form-data">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Moto.Id" />
    <input type="hidden" asp-for="Moto.FotoPrincipal" />

    @if (!string.IsNullOrEmpty(Model.Moto.FotoPrincipal))
    {
        <div class="mb-3">
            <img src="~/uploads/motos/@Model.Moto.FotoPrincipal"
                 width="200"
                 class="img-thumbnail" />
        </div>
    }

    <div class="mb-3">
        <label asp-for="Moto.Modelo"></label>
        <input asp-for="Moto.Modelo" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Moto.MarcaId"></label>
        <select asp-for="Moto.MarcaId"
                asp-items="Model.Marcas"
                class="form-select">
            <option value="">Selecione</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Moto.CategoriaId"></label>
        <select asp-for="Moto.CategoriaId"
                asp-items="Model.Categorias"
                class="form-select">
            <option value="">Selecione</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Moto.CombustivelId"></label>
        <select asp-for="Moto.CombustivelId"
                asp-items="Model.Combustiveis"
                class="form-select">
            <option value="">Selecione</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Moto.Ano"></label>
        <input asp-for="Moto.Ano" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Moto.Cor"></label>
        <input asp-for="Moto.Cor" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Moto.Quilometragem"></label>
        <input asp-for="Moto.Quilometragem" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Moto.Valor"></label>
        <input asp-for="Moto.Valor" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Moto.Descricao"></label>
        <textarea asp-for="Moto.Descricao"
                  class="form-control"
                  rows="4"></textarea>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Moto.Disponivel"
               class="form-check-input" />
        <label asp-for="Moto.Disponivel"
               class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label class="form-label">
            Fotos da Moto
        </label>

        <input asp-for="ArquivosFotos"
               type="file"
               class="form-control"
               accept="image/*"
               multiple />
    </div>

    @if (Model.Moto.Fotos != null && Model.Moto.Fotos.Any())
    {
        <hr />

        <h4>Fotos Cadastradas</h4>

        <div class="row">
            @foreach (var foto in Model.Moto.Fotos.OrderBy(x => x.Ordem))
            {
                <div class="col-md-3 mb-3">

                    @if (foto.Principal)
                    {
                        <span class="badge bg-success mb-2">
                            Principal
                        </span>
                    }

                    <img src="~/uploads/motos/@foto.CaminhoImagem"
                         class="img-thumbnail"
                         style="height:180px;width:100%;object-fit:cover;" />

                </div>
            }
        </div>
    }

   
    

    <button type="submit"
            class="btn btn-success">
        Salvar
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Voltar
    </a>

</form>
    </div>
</div>