@model VianaMotos.Web.Models.Moto

@{
    ViewData["Title"] = $"Detalhes — {Model.Modelo}";

    var fotos = Model.Fotos?
        .OrderByDescending(x => x.Principal)
        .ThenBy(x => x.Ordem)
        .ToList() ?? new();

    var fotoPrincipal = fotos.FirstOrDefault();
}

<style>
    .moto-details-page {
        padding-bottom: 30px;
    }

    .moto-details-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 26px;
    }

    .moto-details-eyebrow {
        display: block;
        margin-bottom: 8px;
        color: var(--viana-red, #c40000);
        font-size: .72rem;
        font-weight: 850;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .moto-details-title {
        margin: 0;
        color: var(--viana-graphite-950, #111317);
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 850;
        line-height: 1;
    }

    .moto-details-subtitle {
        margin: 10px 0 0;
        color: var(--viana-gray-500, #7d8794);
        font-size: .92rem;
    }

    .moto-details-header-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .moto-details-card {
        height: 100%;
        padding: 24px;
        background: #fff;
        border: 1px solid rgba(17, 24, 39, .08);
        border-radius: 20px;
        box-shadow: 0 18px 50px rgba(17, 24, 39, .08);
    }

    .moto-gallery-main {
        position: relative;
        height: 520px;
        overflow: hidden;
        background: #111317;
        border-radius: 16px;
    }

    .moto-gallery-main img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity .2s ease, transform .4s ease;
    }

    .moto-gallery-main:hover img {
        transform: scale(1.015);
    }

    .moto-gallery-main img.is-changing {
        opacity: .35;
    }

    .moto-gallery-count {
        position: absolute;
        right: 16px;
        bottom: 16px;
        padding: 7px 12px;
        color: #fff;
        background: rgba(8, 9, 11, .75);
        border: 1px solid rgba(255, 255, 255, .14);
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 800;
        backdrop-filter: blur(10px);
    }

    .moto-thumbnails {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        padding-bottom: 5px;
        overflow-x: auto;
    }

    .moto-thumbnail {
        width: 100px;
        min-width: 100px;
        height: 76px;
        padding: 0;
        overflow: hidden;
        background: #eef0f3;
        border: 2px solid transparent;
        border-radius: 12px;
        opacity: .68;
        cursor: pointer;
        transition:
            opacity .2s ease,
            border-color .2s ease,
            transform .2s ease;
    }

    .moto-thumbnail:hover {
        opacity: 1;
        transform: translateY(-2px);
    }

    .moto-thumbnail.is-active {
        border-color: var(--viana-red, #c40000);
        opacity: 1;
    }

    .moto-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .moto-empty-gallery {
        display: flex;
        min-height: 520px;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px;
        color: var(--viana-gray-500, #7d8794);
        background: #f6f7f9;
        border: 1px dashed #d7dce4;
        border-radius: 16px;
        text-align: center;
    }

    .moto-empty-gallery strong {
        margin-bottom: 6px;
        color: #111317;
        font-size: 1.05rem;
    }

    .moto-panel-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 25px;
    }

    .moto-status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: .68rem;
        font-weight: 850;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .moto-status::before {
        width: 7px;
        height: 7px;
        background: currentColor;
        border-radius: 50%;
        content: "";
    }

    .moto-status.available {
        color: #138a54;
        background: rgba(19, 138, 84, .1);
    }

    .moto-status.unavailable {
        color: #b42318;
        background: rgba(180, 35, 24, .1);
    }

    .moto-reference {
        color: var(--viana-gray-500, #7d8794);
        font-size: .7rem;
        font-weight: 750;
    }

    .moto-price-label {
        display: block;
        margin-bottom: 5px;
        color: var(--viana-gray-500, #7d8794);
        font-size: .7rem;
        font-weight: 850;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .moto-price {
        margin: 0;
        color: #111317;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 900;
        line-height: 1;
        letter-spacing: -.04em;
    }

    .moto-divider {
        height: 1px;
        margin: 25px 0;
        background: #eceff3;
    }

    .moto-section-title {
        margin: 0 0 16px;
        color: #111317;
        font-size: .8rem;
        font-weight: 850;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .moto-info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .moto-info-item {
        display: flex;
        min-height: 78px;
        flex-direction: column;
        justify-content: center;
        padding: 13px;
        background: #f6f7f9;
        border: 1px solid #eceff3;
        border-radius: 13px;
    }

    .moto-info-item span {
        margin-bottom: 4px;
        color: var(--viana-gray-500, #7d8794);
        font-size: .64rem;
        font-weight: 800;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .moto-info-item strong {
        overflow-wrap: anywhere;
        color: #171a20;
        font-size: .86rem;
        font-weight: 800;
    }

    .moto-description {
        margin: 0;
        color: var(--viana-gray-700, #3f4752);
        font-size: .9rem;
        line-height: 1.75;
        white-space: pre-line;
    }

    .moto-panel-actions {
        display: grid;
        gap: 10px;
        margin-top: 25px;
    }

    .moto-panel-actions .btn {
        width: 100%;
    }

    @@media (max-width: 991.98px) {
        .moto-details-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .moto-details-header-actions {
            width: 100%;
        }

        .moto-details-header-actions .btn {
            flex: 1;
        }

        .moto-gallery-main {
            height: 440px;
        }
    }

    @@media (max-width: 575.98px) {
        .moto-details-card {
            padding: 18px;
            border-radius: 16px;
        }

        .moto-details-header-actions {
            flex-direction: column;
        }

        .moto-details-header-actions .btn {
            width: 100%;
        }

        .moto-gallery-main {
            height: 310px;
        }

        .moto-info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="moto-details-page">

    <header class="moto-details-header">
        <div>
            <span class="moto-details-eyebrow">
                Gestão de estoque
            </span>

            <h1 class="moto-details-title">
                @Model.Modelo
            </h1>

            <p class="moto-details-subtitle">
                Visualize as informações comerciais e as imagens da motocicleta.
            </p>
        </div>

        <div class="moto-details-header-actions">
            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Voltar para motos
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Editar motocicleta
            </a>
        </div>
    </header>

    <div class="row g-4 align-items-stretch">

        <div class="col-lg-8">
            <section class="moto-details-card">
                @if (fotoPrincipal != null)
                {
                    <div class="moto-gallery-main">
                        <img id="mainImage"
                             src="~/uploads/motos/@fotoPrincipal.CaminhoImagem"
                             alt="@Model.Marca?.Nome @Model.Modelo" />

                        <span class="moto-gallery-count">
                            <span id="currentImageNumber">1</span>
                            de @fotos.Count
                        </span>
                    </div>

                    @if (fotos.Count > 1)
                    {
                        <div class="moto-thumbnails"
                             aria-label="Galeria de imagens">
                            @for (var index = 0; index < fotos.Count; index++)
                            {
                                var foto = fotos[index];

                                <button type="button"
                                        class="moto-thumbnail @(foto.Id == fotoPrincipal.Id ? "is-active" : "")"
                                        data-image-index="@index"
                                        data-image-src="@Url.Content($"~/uploads/motos/{foto.CaminhoImagem}")"
                                        aria-label="Mostrar imagem @(index + 1)">
                                    <img src="~/uploads/motos/@foto.CaminhoImagem"
                                         alt="Imagem @(index + 1) de @Model.Modelo" />
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="moto-empty-gallery">
                        <strong>Sem imagens cadastradas</strong>
                        <span>
                            Edite a motocicleta para adicionar imagens ao anúncio.
                        </span>
                    </div>
                }
            </section>
        </div>

        <div class="col-lg-4">
            <aside class="moto-details-card">

                <div class="moto-panel-top">
                    @if (Model.Disponivel)
                    {
                        <span class="moto-status available">
                            Disponível
                        </span>
                    }
                    else
                    {
                        <span class="moto-status unavailable">
                            Indisponível
                        </span>
                    }

                    <span class="moto-reference">
                        ID #@Model.Id
                    </span>
                </div>

                <span class="moto-price-label">
                    Valor anunciado
                </span>

                <h2 class="moto-price">
                    @Model.Valor.ToString("C")
                </h2>

                <div class="moto-divider"></div>

                <h3 class="moto-section-title">
                    Informações da moto
                </h3>

                <div class="moto-info-grid">
                    <div class="moto-info-item">
                        <span>Marca</span>
                        <strong>
                            @(Model.Marca?.Nome ?? "Não informada")
                        </strong>
                    </div>

                    <div class="moto-info-item">
                        <span>Categoria</span>
                        <strong>
                            @(Model.Categoria?.Nome ?? "Não informada")
                        </strong>
                    </div>

                    <div class="moto-info-item">
                        <span>Combustível</span>
                        <strong>
                            @(Model.Combustivel?.Nome ?? "Não informado")
                        </strong>
                    </div>

                    <div class="moto-info-item">
                        <span>Ano</span>
                        <strong>@Model.Ano</strong>
                    </div>

                    <div class="moto-info-item">
                        <span>Cor</span>
                        <strong>
                            @(!string.IsNullOrWhiteSpace(Model.Cor)
                                ? Model.Cor
                                : "Não informada")
                        </strong>
                    </div>

                    <div class="moto-info-item">
                        <span>Quilometragem</span>
                        <strong>
                            @Model.Quilometragem.ToString("N0") km
                        </strong>
                    </div>
                </div>

                <div class="moto-divider"></div>

                <h3 class="moto-section-title">
                    Descrição
                </h3>

                <p class="moto-description">
                    @(!string.IsNullOrWhiteSpace(Model.Descricao)
                        ? Model.Descricao
                        : "Nenhuma descrição cadastrada para esta motocicleta.")
                </p>

                <div class="moto-panel-actions">
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary">
                        Editar motocicleta
                    </a>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        Voltar para a listagem
                    </a>
                </div>

            </aside>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const mainImage = document.getElementById("mainImage");
        const currentImageNumber =
            document.getElementById("currentImageNumber");
        const thumbnails = document.querySelectorAll(".moto-thumbnail");

        if (!mainImage || thumbnails.length === 0) {
            return;
        }

        thumbnails.forEach(function (thumbnail) {
            thumbnail.addEventListener("click", function () {
                const nextSource =
                    thumbnail.getAttribute("data-image-src");
                const imageIndex =
                    thumbnail.getAttribute("data-image-index");

                if (!nextSource) {
                    return;
                }

                mainImage.classList.add("is-changing");

                window.setTimeout(function () {
                    mainImage.src = nextSource;
                    mainImage.classList.remove("is-changing");
                }, 130);

                thumbnails.forEach(function (item) {
                    item.classList.remove("is-active");
                });

                thumbnail.classList.add("is-active");

                if (currentImageNumber && imageIndex !== null) {
                    currentImageNumber.textContent =
                        String(Number(imageIndex) + 1);
                }
            });
        });
    });
</script>
