@model IEnumerable<VianaMotos.Web.Models.Moto>

@{
    ViewData["Title"] = "Motos";
}

<div class="admin-container">

    <header class="page-header">
        <div>
            <h1 class="page-title">Motos</h1>
            <p class="page-subtitle">
                Estoque visual, organizado e pronto para apoiar uma experiencia premium de venda.
            </p>
        </div>

        <div class="page-actions">
            <a asp-action="Create"
               class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>
                Nova Moto
            </a>
        </div>
    </header>

    <section class="table-card">
        <div class="table-card-header">
            <div>
                <h2 class="section-title mb-1">Estoque cadastrado</h2>
                <span class="text-secondary">@Model.Count() motos encontradas</span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Foto</th>
                        <th>Modelo</th>
                        <th>Marca</th>
                        <th>Categoria</th>
                        <th>Ano</th>
                        <th>Valor</th>
                        <th>Status</th>
                        <th class="text-end">Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var moto in Model)
                    {
                        <tr>
                            <td>
                                @if (moto.Fotos != null && moto.Fotos.Any())
                                {
                                    var foto = moto.Fotos
                                        .OrderByDescending(x => x.Principal)
                                        .ThenBy(x => x.Ordem)
                                        .First();

                                    <img src="@ImageUrlHelper.ObterUrl(foto.CaminhoImagem)"
                                         class="admin-thumb"
                                         alt="@moto.Modelo" />
                                }
                                else
                                {
                                    <span class="status-badge is-neutral">Sem foto</span>
                                }
                            </td>

                            <td>
                                <strong class="d-block text-dark">@moto.Modelo</strong>
                                <span class="text-secondary">@moto.Quilometragem km</span>
                            </td>
                            <td>@moto.Marca?.Nome</td>
                            <td>@moto.Categoria?.Nome</td>
                            <td>@moto.Ano</td>
                            <td>
                                <strong class="text-dark">@moto.Valor.ToString("C")</strong>
                            </td>
                            <td>
                                @if (moto.Disponivel)
                                {
                                    <span class="status-badge is-success">Disponível</span>
                                }
                                else
                                {
                                    <span class="status-badge is-danger">Indisponivel</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons justify-content-end">
                                    <a asp-action="Details"
                                       asp-route-id="@moto.Id"
                                       class="btn btn-info btn-sm">
                                        Detalhes
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@moto.Id"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Fotos"
                                       asp-route-id="@moto.Id"
                                       class="btn btn-secondary btn-sm">
                                        Fotos
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@moto.Id"
                                       class="btn btn-danger btn-sm">
                                        Excluir
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>
