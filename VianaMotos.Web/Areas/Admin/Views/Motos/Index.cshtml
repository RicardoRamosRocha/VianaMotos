@model IEnumerable<VianaMotos.Web.Models.Moto>

<div class="admin-container">

    <h1>Motos</h1>

    <p class="mb-4">
        <a asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Nova Moto
        </a>
    </p>

<table class="table">
    <thead>
        <tr>
            <th>Foto</th>
            <th>Modelo</th>
            <th>Marca</th>
            <th>Categoria</th>
            <th>Ano</th>
            <th>Valor</th>
            <th>Disponível</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var moto in Model)
        {
            <tr>
                <td>
                   @if (moto.Fotos != null && moto.Fotos.Any())
                   {
                      var foto = moto.Fotos.OrderBy(x => x.Ordem).First();

                      <img src="~/uploads/motos/@foto.CaminhoImagem"
                      width="100"
                      class="img-thumbnail" />
                   }
                   else
                   {
                   <span>Sem fotos</span>
                   }
                  </td>
                   
                <td>@moto.Modelo</td>
                <td>@moto.Marca?.Nome</td>
                <td>@moto.Categoria?.Nome</td>
                <td>@moto.Ano</td>
                <td>@moto.Valor.ToString("C")</td>
                <td>@(moto.Disponivel ? "Sim" : "Não")</td>
                <td>
                    <a asp-action="Details"
                       asp-route-id="@moto.Id"
                       class="btn btn-info btn-sm">
                        Detalhes
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@moto.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Fotos"
                       asp-route-id="@moto.Id"
                       class="btn btn-secondary btn-sm">
                        Fotos
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@moto.Id"
                       class="btn btn-danger btn-sm">
                        Excluir
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

