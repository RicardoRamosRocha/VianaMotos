@model IEnumerable<VianaMotos.Web.Models.Venda>

@{
    ViewData["Title"] = "Vendas";
}

<div class="container-fluid">

    ```
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Vendas</h2>

        <a asp-action="Create"
           class="btn btn-danger">
            Nova Venda
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Cliente</th>
                        <th>Moto</th>
                        <th>Valor</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @item.DataVenda.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.Cliente?.Nome
                            </td>

                            <td>
                                @item.Moto?.Modelo
                            </td>

                            <td>
                                @item.ValorVenda.ToString("C")
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
    ```

</div>

