@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4 fw-bold">
    Painel Administrativo
</h1>

<div class="row g-4">

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">

                <div class="display-4 mb-2">🏍️</div>

                <h2 class="fw-bold">
                    @ViewBag.TotalMotos
                </h2>

                <p class="text-muted mb-0">
                    Total de Motos
                </p>

            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">

                <div class="display-4 mb-2">✅</div>

                <h2 class="fw-bold">
                    @ViewBag.Disponiveis
                </h2>

                <p class="text-muted mb-0">
                    Disponíveis
                </p>

            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">

                <div class="display-4 mb-2">💰</div>

                <h2 class="fw-bold">
                    @ViewBag.Vendidas
                </h2>

                <p class="text-muted mb-0">
                    Vendidas
                </p>

            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">

                <div class="display-4 mb-2">🏢</div>

                <h2 class="fw-bold">
                    @ViewBag.Marcas
                </h2>

                <p class="text-muted mb-0">
                    Marcas
                </p>

            </div>
        </div>
    </div>

</div>