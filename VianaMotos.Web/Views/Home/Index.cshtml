@model IEnumerable<VianaMotos.Web.Models.Moto>

<div class="container">

    <div class="text-center mb-5 py-5">

        <h1 class="display-3 fw-bold">
            VIANA <span style="color:#c40000;">MOTOS</span>
        </h1>

        <p class="lead text-light">
            As melhores motocicletas em um só lugar
        </p>

    </div>

    <div class="row g-4">

        @foreach (var moto in Model)
        {
            var fotoPrincipal = moto.Fotos?
                .FirstOrDefault(x => x.Principal);

            <div class="col-lg-4 col-md-6">

                <div class="card shadow h-100">

                    @if (fotoPrincipal != null)
                    {
                        <img src="~/uploads/motos/@fotoPrincipal.CaminhoImagem"
                             class="card-img-top"
                             style="height:250px;object-fit:cover;">
                    }

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold">
                            @moto.Modelo
                        </h5>

                        <p class="text-muted mb-1">
                            @moto.Marca?.Nome
                        </p>

                        <p class="mb-1">
                            <strong>Ano:</strong> @moto.Ano
                        </p>

                        <p class="mb-3">
                            <strong>KM:</strong> @moto.Quilometragem
                        </p>

                        <h4 class="text-success mb-3">
                            @moto.Valor.ToString("C")
                        </h4>

                        <a asp-controller="Home"
                           asp-action="Details"
                           asp-route-id="@moto.Id"
                           class="btn btn-primary mt-auto">
                            Ver Detalhes
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>