@model VianaMotos.Web.Models.Moto

@{
    ViewData["Title"] = Model.Modelo;
    var fotos = Model.Fotos.OrderByDescending(x => x.Principal).ThenBy(x => x.Ordem).ToList();
    var principal = fotos.FirstOrDefault();
}

<section class="details-hero">
    <div class="container">
        <div class="row g-5 align-items-start">

            <div class="col-lg-7">
                @if (principal != null)
                {
                    <div class="gallery">
                        <div class="gallery-main">
                            <img id="mainGalleryImage"
                                 src="@ImageUrlHelper.ObterUrl(principal.CaminhoImagem)"
                                 alt="@Model.Modelo" />
                        </div>

                        <div class="gallery-thumbnails">
                            @foreach (var foto in fotos)
                            {
                                <button type="button"
                                        class="gallery-thumbnail @(foto.Id == principal.Id ? "is-active" : "")"
                                        data-gallery-src="@ImageUrlHelper.ObterUrl(foto.CaminhoImagem)"
                                        aria-label="Ver foto da moto">
                                    <img src="@ImageUrlHelper.ObterUrl(foto.CaminhoImagem)"
                                         alt="@Model.Modelo" />
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Fotos em breve.
                    </div>
                }
            </div>

            <div class="col-lg-5">
                <aside class="details-panel">
                    <div class="details-panel-top">
                        @if (Model.Disponivel)
                        {
                            <span class="details-status is-available">
                                Disponível
                            </span>
                        }
                        else
                        {
                            <span class="details-status is-unavailable">
                                Indisponível
                            </span>
                        }
                    </div>

                    <h1 class="details-title">@Model.Modelo</h1>
                    <div class="details-brand">
                        @Model.Marca?.Nome
                    </div>

                    <div class="details-price">
                        @Model.Valor.ToString("C")
                    </div>

                    <div class="details-spec-grid">
                        <div class="spec-card">
                            <strong>Ano</strong>
                            @Model.Ano
                        </div>

                        <div class="spec-card">
                            <strong>Quilometragem</strong>
                            @Model.Quilometragem km
                        </div>

                        <div class="spec-card">
                            <strong>Cor</strong>
                            @(Model.Cor ?? "Não informada")
                        </div>

                        <div class="spec-card">
                            <strong>Combustível</strong>
                            @Model.Combustivel?.Nome
                        </div>

                        <div class="spec-card">
                            <strong>Categoria</strong>
                            @Model.Categoria?.Nome
                        </div>

                        <div class="spec-card">
                            <strong>Status</strong>
                            @(Model.Disponivel ? "Disponível" : "Indisponível")
                        </div>
                    </div>

                    <div class="details-actions">
                        <a asp-area="Admin"
                           asp-controller="Simulador"
                           asp-action="Index"
                           class="primary-cta">
                            Simular parcelas
                        </a>

                        <a href="#interesse"
                           class="secondary-cta">
                            Tenho interesse
                        </a>

                        <a asp-action="Index"
                           class="secondary-cta">
                            Voltar ao estoque
                        </a>
                    </div>
                </aside>
            </div>

        </div>
    </div>
</section>

<section id="interesse" class="container mb-5">
    <div class="description-card">
        <h2>Descrição</h2>
        <p>
            @(!string.IsNullOrWhiteSpace(Model.Descricao)
                ? Model.Descricao
                : "Esta motocicleta está disponível para consulta. Entre em contato com a equipe para receber mais informações sobre condição, documentação e possibilidades de negociação.")
        </p>

        <div class="details-actions">
            <a href="/#estoque" class="primary-cta">
                Ver outras motos
            </a>
            <a asp-action="Index" class="secondary-cta">
                Voltar ao estoque
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.gallery-thumbnail').forEach(function (button) {
            button.addEventListener('click', function () {
                var mainImage = document.getElementById('mainGalleryImage');
                var nextSrc = button.getAttribute('data-gallery-src');

                if (!mainImage || !nextSrc) {
                    return;
                }

                mainImage.setAttribute('src', nextSrc);

                document.querySelectorAll('.gallery-thumbnail').forEach(function (item) {
                    item.classList.remove('is-active');
                });

                button.classList.add('is-active');
            });
        });
    </script>
}
